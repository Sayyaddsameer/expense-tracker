# ---------------------------------------------------------------------------
# .env.example
# Copy this file to .env and fill in the values before running docker-compose.
# NEVER commit the actual .env file to version control.
# ---------------------------------------------------------------------------

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Credentials for the PostgreSQL database service (used by docker-compose)
POSTGRES_USER=expense_user
POSTGRES_PASSWORD=your-strong-password-here
POSTGRES_DB=expense_tracker

# ── Application Database URL ────────────────────────────────────────────────
# Full connection string consumed by SQLAlchemy inside the API container.
# When running via docker-compose this is automatically overridden to point
# at the 'db' service; set it here only for local/non-Docker development.
DATABASE_URL=postgresql://expense_user:your-strong-password-here@localhost:5432/expense_tracker

# ── API Server ──────────────────────────────────────────────────────────────
# Port on which the FastAPI application listens (inside and outside the container)
API_PORT=8000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS (use * to allow all).
# Restrict this in production to your frontend domain(s).
ALLOWED_ORIGINS=*

# ── Connection Pool ──────────────────────────────────────────────────────────
# SQLAlchemy connection pool settings (ignored when using SQLite)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── SQLite (local dev without Docker) ───────────────────────────────────────
# Used only when DATABASE_URL is not set.
SQLITE_PATH=./expenses.db
